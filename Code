        self.root.title("Defensa y Asalto de Base - Inicio")
        self.root.geometry("400x500")
        self.gestion          = GestionUsuarios()
        self.jugador_defensor = None
        self.jugador_atacante = None
        self.var_usuario      = tk.StringVar()
        self.var_contra       = tk.StringVar()
        self.crear_interfaz()

    def crear_interfaz(self):
        tk.Label(self.root, text="Registro / Login",
                 font=("Arial", 16, "bold")).pack(pady=20)

        self.lbl_estado = tk.Label(
            self.root, text="Inicie sesión para el JUGADOR 1 (DEFENSOR)",
            font=("Arial", 10, "italic"), fg="blue")
        self.lbl_estado.pack(pady=5)

        tk.Label(self.root, text="Nombre de Usuario:").pack(pady=5)
        tk.Entry(self.root, textvariable=self.var_usuario,
                 font=("Arial", 11)).pack(pady=5)

        tk.Label(self.root, text="Contraseña:").pack(pady=5)
        tk.Entry(self.root, textvariable=self.var_contra,
                 show="*", font=("Arial", 11)).pack(pady=5)

        tk.Button(self.root, text="Iniciar Sesión", width=18,
                  bg="#4CAF50", fg="white", command=self.procesar_login).pack(pady=5)
        tk.Button(self.root, text="Registrarse", width=18,
                  bg="#2196F3", fg="white", command=self.procesar_registro).pack(pady=5)

        tk.Button(self.root, text="🏆 Ver Tabla de Posiciones", width=22,
                  bg="#F39C12", fg="white", font=("Arial", 9, "bold"),
                  command=lambda: VentanaRankings(self.root, self.gestion)).pack(pady=10)

        self.lbl_listos = tk.Label(self.root,
                                   text="Defensor: --  |  Atacante: --",
                                   font=("Arial", 10, "bold"), pady=15)
        self.lbl_listos.pack()

    def procesar_registro(self):
        u = self.var_usuario.get().strip()
        c = self.var_contra.get().strip()
        exito, msg = self.gestion.registrar_usuario(u, c)
        if exito:
            messagebox.showinfo("Éxito", msg)
            self.limpiar()
        else:
            messagebox.showerror("Error", msg)

    def procesar_login(self):
        u = self.var_usuario.get().strip()
        c = self.var_contra.get().strip()
        exito, msg = self.gestion.iniciar_sesion(u, c)
        if not exito:
            messagebox.showerror("Error", msg)
            return
        if u == self.jugador_defensor or u == self.jugador_atacante:
            messagebox.showwarning("Advertencia", "Este jugador ya está autenticado.")
            return

        if not self.jugador_defensor:
            self.jugador_defensor = u
            messagebox.showinfo("Éxito", f"{u} ingresará como DEFENSOR.")
            self.lbl_estado.config(text="Inicie sesión para el JUGADOR 2 (ATACANTE)")
        elif not self.jugador_atacante:
            self.jugador_atacante = u
            messagebox.showinfo("Éxito", f"{u} ingresará como ATACANTE.")

        self.act_etiqueta()
        self.limpiar()

        if self.jugador_defensor and self.jugador_atacante:
            def_f, atk_f = self.jugador_defensor, self.jugador_atacante
            self.root.destroy()
            fac_raiz = tk.Tk()
            VentanaFacciones(fac_raiz, def_f, atk_f, self.gestion)
            fac_raiz.mainloop()

    def act_etiqueta(self):
        d = self.jugador_defensor if self.jugador_defensor else "--"
        a = self.jugador_atacante if self.jugador_atacante else "--"
        self.lbl_listos.config(text=f"Defensor: {d}  |  Atacante: {a}")

    def limpiar(self):
        self.var_usuario.set("")
        self.var_contra.set("")


