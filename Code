# 2. MODELADO DE ESTRUCTURAS DEFENSIVAS (ROL DEL DEFENSOR)
# =====================================================================
class BaseEstructura:
    def __init__(self, nombre, costo, vida, ruta_imagen):
        self.nombre      = nombre
        self.costo       = costo
        self.vida        = vida
        self.vida_maxima = vida
        self.ruta_imagen = ruta_imagen

class BaseCentral(BaseEstructura):
    def __init__(self, faccion_defensor):
        super().__init__("Base Central", costo=0, vida=500, ruta_imagen=faccion_defensor.ruta_base)

class Muro(BaseEstructura):
    def __init__(self, faccion_defensor):
        vida_base = 150
        # Ventaja Medieval: muros con 5% más de vida
        if faccion_defensor.nombre == "Medieval":
            vida_base = int(vida_base * 1.05)
        super().__init__("Muro", costo=20, vida=vida_base, ruta_imagen=faccion_defensor.ruta_muro)

class Torre(BaseEstructura):
    def __init__(self, nombre, costo, vida, daño, alcance, cooldown_habilidad, ruta_imagen):
        super().__init__(nombre, costo, vida, ruta_imagen)
        self.daño              = daño
        self.alcance           = alcance
        self.cooldown_habilidad = cooldown_habilidad
        self.contador_turnos   = 0
        self.habilidad_activa  = False   # se vuelve True cuando el cooldown se cumple

    def avanzar_turno(self):
        """Incrementa el contador y activa la habilidad si se alcanzó el cooldown."""
        self.contador_turnos += 1
        if self.contador_turnos >= self.cooldown_habilidad:
            self.habilidad_activa = True
            self.contador_turnos  = 0

    # ---------- Habilidades especiales (una por subclase) ----------
    def activar_habilidad(self, unidades_en_mapa, log_fn):
        """Método base; cada subclase lo sobreescribe."""
        pass


class TorreBasica(Torre):
    """Habilidad: Disparo doble — ataca a DOS unidades distintas en lugar de una."""
    def __init__(self, faccion_defensor):
        super().__init__("Torre Básica", costo=50, vida=100, daño=15,
                         alcance=2, cooldown_habilidad=3,
                         ruta_imagen=faccion_defensor.torre_basica)

    def activar_habilidad(self, unidades_en_mapa, log_fn):
        if not self.habilidad_activa:
            return 0
        self.habilidad_activa = False
        objetivos = unidades_en_mapa[:2]          # hasta 2 unidades
        dano_total = 0
        for unidad in objetivos:
            unidad.vida -= self.daño
            dano_total  += self.daño
            log_fn(f"⚡ [{self.nombre}] DISPARO DOBLE → {unidad.nombre} -{self.daño} HP (restante: {max(unidad.vida,0)})")
        return dano_total


class TorrePesada(Torre):
    """Habilidad: Daño en área — golpea a TODAS las unidades presentes en el mapa."""
    def __init__(self, faccion_defensor):
        super().__init__("Torre Pesada", costo=120, vida=250, daño=40,
                         alcance=3, cooldown_habilidad=4,
                         ruta_imagen=faccion_defensor.torre_pesada)

    def activar_habilidad(self, unidades_en_mapa, log_fn):
        if not self.habilidad_activa:
            return 0
        self.habilidad_activa = False
        dano_area = self.daño // 2          # 20 de daño en área
        dano_total = 0
        for unidad in unidades_en_mapa:
            unidad.vida -= dano_area
            dano_total  += dano_area
            log_fn(f"💥 [{self.nombre}] DAÑO EN ÁREA → {unidad.nombre} -{dano_area} HP (restante: {max(unidad.vida,0)})")
        return dano_total


class TorreMagica(Torre):
    """Habilidad: Daño persistente (veneno) — aplica marca que quita HP extra cada turno."""
    def __init__(self, faccion_defensor):
        super().__init__("Torre Mágica", costo=90, vida=120, daño=10,
                         alcance=4, cooldown_habilidad=2,
                         ruta_imagen=faccion_defensor.torre_magica)
        # Facción Oscura potencia: 2% extra de daño persistente por turno
        self.daño_persistente = 8

    def activar_habilidad(self, unidades_en_mapa, log_fn):
        if not self.habilidad_activa:
            return 0
        self.habilidad_activa = False
        dano_total = 0
        for unidad in unidades_en_mapa:
            if not hasattr(unidad, 'turnos_veneno'):
                unidad.turnos_veneno = 0
            unidad.turnos_veneno += 3       # envenena por 3 turnos
            unidad.vida -= self.daño_persistente
            dano_total  += self.daño_persistente
            log_fn(f"🧪 [{self.nombre}] VENENO → {unidad.nombre} -{self.daño_persistente} HP + 3 turnos veneno")
        return dano_total


# =====================================================================
# 3. MODELADO DE UNIDADES ATACANTES (ROL DEL ATACANTE)
# =====================================================================
class UnidadAtacante:
    def __init__(self, nombre, costo, vida, daño, velocidad, cooldown_habilidad, ruta_imagen):
        self.nombre            = nombre
        self.costo             = costo
        self.vida              = vida
        self.vida_maxima       = vida
        self.daño              = daño
        self.velocidad         = velocidad
        self.cooldown_habilidad = cooldown_habilidad
        self.contador_turnos   = 0
        self.habilidad_activa  = False
        self.ruta_imagen       = ruta_imagen
        self.turnos_veneno     = 0      # usado por TorreMagica

    def avanzar_turno(self):
        self.contador_turnos += 1
        if self.contador_turnos >= self.cooldown_habilidad:
            self.habilidad_activa = True
            self.contador_turnos  = 0
        # Aplicar daño de veneno si corresponde
        if self.turnos_veneno > 0:
            self.vida          -= 5
            self.turnos_veneno -= 1

    # ---------- Habilidades especiales (una por subclase) ----------
    def activar_habilidad(self, base_obj, log_fn):
        pass


class SoldadoBasico(UnidadAtacante):
    """Habilidad: Ataque doble — inflige el doble de daño a la base en ese turno."""
    def __init__(self, faccion_atacante):
        super().__init__("Soldado Básico", costo=30, vida=90, daño=15,
                         velocidad=1, cooldown_habilidad=3,
                         ruta_imagen=faccion_atacante.unidad_soldado)

    def activar_habilidad(self, base_obj, log_fn):
        if not self.habilidad_activa:
            return 0
        self.habilidad_activa = False
        dano = self.daño * 2
        base_obj.vida -= dano
        log_fn(f"⚔️  [{self.nombre}] ATAQUE DOBLE → Base -{dano} HP (restante: {max(base_obj.vida,0)})")
        return dano


class Tanque(UnidadAtacante):
    """Habilidad: Escudo temporal — regenera 40 HP propios (sin superar vida_maxima)."""
    def __init__(self, faccion_atacante):
        super().__init__("Tanque", costo=100, vida=250, daño=25,
                         velocidad=1, cooldown_habilidad=4,
                         ruta_imagen=faccion_atacante.unidad_tanque)

    def activar_habilidad(self, base_obj, log_fn):
        if not self.habilidad_activa:
            return 0
        self.habilidad_activa = False
        curacion = 40
        self.vida = min(self.vida + curacion, self.vida_maxima)
        log_fn(f"🛡️  [{self.nombre}] ESCUDO — regenera {curacion} HP (vida actual: {self.vida})")
        return 0   # habilidad defensiva, no daña la base


class UnidadRapida(UnidadAtacante):
    """Habilidad: Velocidad aumentada — se mueve 2 casillas extra ese turno."""
    def __init__(self, faccion_atacante):
        super().__init__("Unidad Rápida", costo=55, vida=70, daño=10,
                         velocidad=3, cooldown_habilidad=2,
                         ruta_imagen=faccion_atacante.unidad_rapida)
        self.bonus_velocidad = 0    # casillas extra activas este turno

    def activar_habilidad(self, base_obj, log_fn):
        if not self.habilidad_activa:
            return 0
        self.habilidad_activa = False
        self.bonus_velocidad  = 2
        log_fn(f"💨 [{self.nombre}] VELOCIDAD AUMENTADA — +2 casillas extra este turno")
        return 0


