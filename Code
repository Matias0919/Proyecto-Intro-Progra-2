# 4. GESTIÓN DE JUGADORES Y PERSISTENCIA JSON
# =====================================================================
class Usuario:
    def __init__(self, username, password, victorias_defensor=0, victorias_atacante=0):
        self.username           = username
        self.password           = password
        self.victorias_defensor = victorias_defensor
        self.victorias_atacante = victorias_atacante

    def to_dict(self):
        return {
            "password": self.password,
            "victorias_defensor": self.victorias_defensor,
            "victorias_atacante": self.victorias_atacante
        }

class GestionUsuarios:
    def __init__(self):
        self.jugadores = {}
        self.cargar_jugadores()

    def cargar_jugadores(self):
        if os.path.exists(ARCHIVO_JUGADORES):
            try:
                with open(ARCHIVO_JUGADORES, 'r', encoding='utf-8') as f:
                    self.jugadores = json.load(f)
            except json.JSONDecodeError:
                self.jugadores = {}
        else:
            self.jugadores = {}

    def guardar_jugadores(self):
        with open(ARCHIVO_JUGADORES, 'w', encoding='utf-8') as f:
            json.dump(self.jugadores, f, indent=4, ensure_ascii=False)

    def registrar_usuario(self, username, password):
        if not username or not password:
            return False, "Los campos no pueden estar vacíos."
        if username in self.jugadores:
            return False, "El nombre de usuario ya existe."
        nuevo = Usuario(username, password)
        self.jugadores[username] = nuevo.to_dict()
        self.guardar_jugadores()
        return True, "Usuario registrado con éxito."

    def iniciar_sesion(self, username, password):
        if username in self.jugadores and self.jugadores[username]["password"] == password:
            return True, "Inicio de sesión correcto."
        return False, "Usuario o contraseña incorrectos."

    def registrar_victoria_global(self, username, rol):
        if username in self.jugadores:
            if rol == "Defensor":
                self.jugadores[username]["victorias_defensor"] += 1
            else:
                self.jugadores[username]["victorias_atacante"] += 1
            self.guardar_jugadores()


