class VentanaFacciones:
    def __init__(self, root, jugador_defensor, jugador_atacante, gestion_usuarios):
        self.root = root
        self.root.title("Selección de Facciones")
        self.root.geometry("520x380")
        self.defensor        = jugador_defensor
        self.atacante        = jugador_atacante
        self.gestion_usuarios = gestion_usuarios
        self.nombre_fac_def  = tk.StringVar(value="Seleccionar")
        self.nombre_fac_ata  = tk.StringVar(value="Seleccionar")
        self.opciones_nombres = [f.nombre for f in LISTA_FACCIONES]
        self.crear_interfaz()

    def crear_interfaz(self):
        tk.Label(self.root, text="¡Seleccionen sus Facciones!",
                 font=("Arial", 14, "bold")).pack(pady=15)

        marco_def = tk.LabelFrame(self.root, text=f"Defensor: {self.defensor}",
                                  padx=10, pady=10)
        marco_def.pack(pady=8, fill="x", padx=20)
        tk.Label(marco_def, text="Facción:").pack(side="left")
        tk.OptionMenu(marco_def, self.nombre_fac_def, *self.opciones_nombres,
                      command=self.act_ventaja_def).pack(side="left", padx=10)
        self.lbl_v_def = tk.Label(marco_def, text="", font=("Arial", 9, "italic"), fg="purple")
        self.lbl_v_def.pack(side="left")

        marco_ata = tk.LabelFrame(self.root, text=f"Atacante: {self.atacante}",
                                  padx=10, pady=10)
        marco_ata.pack(pady=8, fill="x", padx=20)
        tk.Label(marco_ata, text="Facción:").pack(side="left")
        tk.OptionMenu(marco_ata, self.nombre_fac_ata, *self.opciones_nombres,
                      command=self.act_ventaja_ata).pack(side="left", padx=10)
        self.lbl_v_ata = tk.Label(marco_ata, text="", font=("Arial", 9, "italic"), fg="purple")
        self.lbl_v_ata.pack(side="left")

        tk.Button(self.root, text="Confirmar y Jugar", bg="#4CAF50", fg="white",
                  font=("Arial", 11, "bold"), command=self.validar).pack(pady=20)

    def buscar_faccion(self, nombre):
        for f in LISTA_FACCIONES:
            if f.nombre == nombre: return f
        return None

    def act_ventaja_def(self, sel):
        f = self.buscar_faccion(sel)
        if f: self.lbl_v_def.config(text=f.ventaja)

    def act_ventaja_ata(self, sel):
        f = self.buscar_faccion(sel)
        if f: self.lbl_v_ata.config(text=f.ventaja)

    def validar(self):
        n_def = self.nombre_fac_def.get()
        n_ata = self.nombre_fac_ata.get()
        if n_def == "Seleccionar" or n_ata == "Seleccionar":
            messagebox.showerror("Error", "Ambos jugadores deben elegir una facción.")
            return
        if n_def == n_ata:
            messagebox.showerror("Restricción", "No se puede seleccionar la misma facción.")
            return
        obj_def = self.buscar_faccion(n_def)
        obj_ata = self.buscar_faccion(n_ata)
        self.root.destroy()
        mapa_raiz = tk.Tk()
        MapaJuego(mapa_raiz, self.defensor, obj_def, self.atacante, obj_ata, self.gestion_usuarios)
        mapa_raiz.mainloop()


